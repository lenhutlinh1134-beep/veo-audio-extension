{
  "manifest_version": 3,
  "name": "VEO Audio — AI Studio TTS",
  "version": "1.0",
  "description": "Tự động tạo giọng đọc hàng loạt trên Google AI Studio Text-to-Speech",
  "permissions": ["activeTab", "scripting", "storage", "downloads", "sidePanel", "tabs"],
  "host_permissions": ["https://aistudio.google.com/*"],
  "background": { "service_worker": "src/background.js" },
  "action": { "default_title": "VEO Audio TTS" },
  "side_panel": { "default_path": "sidepanel.html" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
